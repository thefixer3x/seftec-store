# Supabase Configuration
# Both Next.js (NEXT_PUBLIC_*) and Vite (VITE_*) environment variables are required for compatibility.
# Set the VITE_SUPABASE_* variables to the same values as the NEXT_PUBLIC_SUPABASE_* variables below.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Vite naming (for compatibility) - use same values as above
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
VITE_SUPABASE_PROJECT_ID=your-project-id

# Sentry Error Tracking
# Get your DSN from: https://lan-onasis.sentry.io/projects/seftecub/settings/keys/
# Runtime error capture in the browser. Safe to omit locally.
VITE_SENTRY_DSN=https://examplePublicKey@o4509402281869312.ingest.sentry.io/4509402281869312
# Build-time sourcemap upload. Only required in CI/production builds that should
# publish source maps to Sentry. If omitted, the app still builds normally.
SENTRY_AUTH_TOKEN=your-sentry-auth-token
# Optional: enables verbose Sentry build logs when troubleshooting upload issues.
SENTRY_DEBUG=false

# PayPal Integration
PAYPAL_CLIENT_ID=your-client-id
PAYPAL_CLIENT_SECRET=your-client-secret
PAYPAL_WEBHOOK_ID=your-webhook-id
PAYPAL_MODE=sandbox # or production
PAYPAL_RETURN_URL=https://seftechub.com/payment/success
PAYPAL_CANCEL_URL=https://seftechub.com/payment/cancel

# SaySwitch Integration
SAYSWITCH_BASE_URL=https://backendapi.sayswitchgroup.com/api/v1
SAYSWITCH_SECRET_KEY=your-secret-key
SAYSWITCH_PUBLIC_KEY=your-public-key

# Stripe Integration
STRIPE_SECRET_KEY=your-secret-key
STRIPE_PUBLISHABLE_KEY=your-publishable-key
STRIPE_WEBHOOK_SECRET=your-webhook-secret

# E-Doc Banking Integration
EDOC_API_KEY=your-api-key
EDOC_SECRET=your-secret
EDOC_WEBHOOK_SECRET=your-webhook-secret
